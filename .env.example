# AWS Profile must be one of:
#   - Management/payer account, OR
#   - An account that is delegated admin for BOTH:
#     1. AWS Config (config.amazonaws.com)
#     2. CloudFormation StackSets (member.org.stacksets.cloudformation.amazonaws.com)
AWS_PROFILE=your-aws-profile
AWS_REGION=us-west-2
ORG_ROOT_OU_ID=r-xxxx

# Prefix for all resource names. All resources are named as {PREFIX}{ResourceType}.
# Example with PREFIX=ServiceNow:
#   ServiceNowAggregatorRole, ServiceNowAggregator,
#   ServiceNowMemberAccountRole, ServiceNowUser
# For testing, use a different prefix (e.g. MyTest)
SERVICENOW_PREFIX=ServiceNow

# Config aggregator settings
CONFIG_RESOURCE_TYPES=AWS::EC2::Instance
CONFIG_REGIONS=us-west-2
